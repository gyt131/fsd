Using Switch Statement

import React from "react";
function Status({ status }) {
switch (status) {
case "loading":
return <p>Loading...</p>;
case "success":
return <p>Data loaded!</p>;
case "error":
return <p>Error occurred.</p>;
default:
return null; }}
export default App;
