Basic List Rendering with map()
import React from "react";
function FruitList() {
const fruits = ["Apple", "Banana", "Orange"];
return (
<ul>
{fruits.map((fruit, index) => (
<li key={index}>{fruit}</li>
))}
</ul> );}
function App() {
return (
<div>
<h2>Fruit List</h2>
<FruitList />
</div> );}
export default App;
Rendering List of Objects
import React from "react";
function UserList() {
const users = [
{ id: 1, name: "John" },
{ id: 2, name: "Jane" },
{ id: 3, name: "Mike" } ];
return (
<ul>
{users.map(user => (
<li key={user.id}>{user.name}</li>
))}
</ul> );}
function App() {
return ( <div> <h2>User List</h2>
<UserList />
</div>)}
export default App;
Rendering Components in a List
import React from "react";
function Product({ name, price }) {
return (
<div>
<h3>{name}</h3>
<p>${price}</p>
</div> );}
function ProductList() {
const products = [
{ id: 1, name: "Laptop", price: 1000 },
{ id: 2, name: "Phone", price: 500 }];
return (
<div>
{products.map(product => (
<Product
key={product.id}
name={product.name}
price={product.price} /> ))}
</div> );}
function App() {
return (
<div>
<h2>Product List</h2>
<ProductList />
</div> );}
export default App;
Conditional Rendering Inside Lists
import React from "react";
function UserList() {
const users = [
{ id: 1, name: "John", isActive: true },
{ id: 2, name: "Jane", isActive: false },
{ id: 3, name: "Mike", isActive: true }
];
return (
<ul>
{users
.filter(user => user.isActive)
.map(user => (
<li key={user.id}>{user.name}</li>
))}
</ul> );}
function App() {
return (
<div>
<h2>Active Users</h2>
<UserList />
</div>
);
}
export default App;
